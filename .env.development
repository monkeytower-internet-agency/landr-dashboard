# Loaded by Vite ONLY in dev mode (npm run dev). Production builds use the
# .env file written by .github/workflows/deploy.yml at build time.
#
# VITE_DEPLOY_TIER tells the dashboard "this build is the DEV tier" — the
# /release console + the chrome TierBadge gate on this. Without it the
# release page shows "Deploy tier unknown" and disables promote buttons.
VITE_DEPLOY_TIER=dev
