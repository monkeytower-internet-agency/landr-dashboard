# Supabase Kong API URL
# Dev (Trillian via Caddy): https://kong.dev.landr.de
# Prod: https://<project>.supabase.co
VITE_SUPABASE_URL=https://kong.dev.landr.de

# Supabase publishable (anon) key — get from `supabase status` on Trillian
VITE_SUPABASE_PUB_KEY=sb_publishable_...

# LANDR FastAPI base URL (no trailing slash)
# Dev (Trillian via Caddy): https://api.dev.landr.de
# Prod: https://api.landr.de
VITE_API_BASE_URL=https://api.dev.landr.de
