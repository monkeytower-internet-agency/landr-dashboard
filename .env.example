# Dev (Trillian via Caddy): https://kong.dev.landr.de
# Prod: https://lksfplmvhmunxrzxhhyo.supabase.co
VITE_SUPABASE_URL=https://kong.dev.landr.de

# Supabase publishable (anon) key
# Dev: sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH (set via VITE_SUPABASE_PUB_KEY_DEV secret)
# Prod: stored in VITE_SUPABASE_PUB_KEY GitHub secret
VITE_SUPABASE_PUB_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# LANDR FastAPI base URL (no trailing slash)
# Dev (Trillian via Cloudflare Tunnel, public): https://api-dev.landr.de
#   (api.dev.landr.de — dotted — is the Tailscale-only Caddy edge; use the dashed public host so dev matches staging/prod topology)
# Prod (GCP Cloud Run): https://landr-api-service-693721943357.europe-west3.run.app
VITE_API_BASE_URL=https://api-dev.landr.de

# Deploy-tier marker (landr-7dya.19). Injected per-branch by deploy.yml:
#   dev branch    → dev
#   staging branch → staging
#   main branch   → prod
# Leave unset locally for a prod-like UI (badge hidden).
# VITE_DEPLOY_TIER=dev

# Sentry error monitoring (landr-52ik.1). STRICTLY gated: unset/empty ⇒
# src/lib/sentry.ts::initSentry() is a complete no-op — this is how it ships
# until a Sentry project is created (human-only action). Provisioning:
#   1. Create a Sentry project (React) — landr-dashboard.
#   2. Set VITE_SENTRY_DSN as a GITHUB ACTIONS secret (repo secrets) — NOT a
#      Cloudflare Pages dashboard env var. This pipeline builds the static
#      Vite bundle in GitHub Actions and only uploads dist/ via `wrangler
#      pages deploy`, so a CF-dashboard env var never reaches the build
#      (see the requirements comment in .github/workflows/deploy.yml).
# One DSN shared across dev/staging/prod; the Sentry `environment` tag comes
# from VITE_DEPLOY_TIER so the tiers stay distinguishable in one project.
# Release tag comes from VITE_COMMIT_SHA (set by
# .github/workflows/deploy.yml from ${{ github.sha }}). No dev value
# needed — leave unset locally.
VITE_SENTRY_DSN=REPLACE_ME
